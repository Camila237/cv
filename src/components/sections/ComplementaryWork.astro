---
import Section from "../Section.astro"
import type { CV } from "@/cv"
import { getLabels } from "@/lib/i18n"

interface Props {
  work: CV["work"]
  title: string
  print?: boolean
}

const { work, title, print: printMode } = Astro.props
const labels = getLabels(Astro.url.pathname)

const formatDate = (dateStr: string | number | Date | null) => {
  if (!dateStr) return labels.current
  return new Date(dateStr).toLocaleDateString(Astro.url.pathname.includes("/en") ? "en-US" : "es-ES", { month: "short", year: "numeric" })
}
---

<Section title={title}>
  <div class="experience-list">
    {
      work.map((job) => {
        const highlights = job.highlights ?? []

        return (
          <details class="experience" open={printMode}>
            <summary>
              <span class="role">
                <strong>{job.position}</strong>
                <span>{job.name}</span>
              </span>
              <span class="period">
                {formatDate(job.startDate)} — {formatDate(job.endDate)}
              </span>
            </summary>

            <div class="experience-content">
              {highlights.length > 0 && (
                <ul class="work-highlights">
                  {highlights.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>
          </details>
        )
      })
    }
  </div>
</Section>

<style>
  .experience-list { display: grid; gap: 0.65rem; }
  .experience { border: 1px solid #e8e8e8; border-radius: 8px; background: #fff; }
  summary { cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.85rem 1rem; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: "+"; color: #777; font-size: 1.1rem; }
  details[open] > summary::after { content: "−"; }
  .role { display: grid; gap: 0.15rem; }
  .role strong { color: #111; font-family: system-ui, sans-serif; font-size: 0.95rem; }
  .role span, .period { color: #666; font-size: 0.82rem; }
  .period { white-space: nowrap; }
  .experience-content { border-top: 1px solid #eee; padding: 0.85rem 1rem 1rem; }
  .experience-content > p { font-size: 0.85rem; }
  .work-highlights { display: grid; gap: 0.35rem; margin: 0.7rem 0 0; }
  .work-highlights li { border-left: 2px solid #cfcfcf; color: #444; font-size: 0.78rem; line-height: 1.4; padding-left: 0.6rem; }
  
  @media print {
    .experience { border: 0; border-radius: 0; break-inside: avoid; position: relative; }
    .experience:not(:last-child) { padding-bottom: 0.5rem; margin-bottom: 0.5rem; border-bottom: 1px solid #ddd; }
    .experience summary { cursor: default; display: block; padding: 0; }
    .experience summary::after { display: none; }
    .role { display: inline; }
    .role strong { font-weight: 500; }
    .role strong::after { content: " · "; font-weight: normal; }
    .role span { color: #222; }
    .period { display: none; } /* Ocultar período para experiencia complementaria en print */
    .experience-content { border: 0; display: block; padding: 0; }
    .experience:not([open]) > .experience-content { display: block !important; }
    .experience-content > p { display: none; } /* Ocultar el resumen en print */
    .work-highlights { display: block; list-style: disc; margin: 0.15rem 0 0; padding-left: 1rem; }
    .work-highlights li { border: 0; font-size: 0.75rem; line-height: 1.3; padding-left: 0; }
  }
</style>
