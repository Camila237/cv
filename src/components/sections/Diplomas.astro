---
import Section from "../Section.astro"
import { getCv } from "@/data/cv"
import { getLabels } from "@/lib/i18n"
const { diplomas } = getCv(Astro.url.pathname)
const labels = getLabels(Astro.url.pathname)

interface Props {
  print?: boolean
  title?: string
}

type DiplomaGroup = {
  institution: string
  area: string
  studyType: string
  courses: string[]
  featuredCourses?: string[]
  printLimit?: number
}

function groupByInstitution(entries: DiplomaGroup[]): Record<string, DiplomaGroup[]> {
  const grouped: Record<string, DiplomaGroup[]> = {}
  for (const entry of entries) {
    const institution = entry.institution || "Other diplomas"
    if (!grouped[institution]) grouped[institution] = []
    grouped[institution].push(entry)
  }
  return grouped
}

const printMode = Astro.props.print ?? false
const title = Astro.props.title ?? labels.diplomas
const groupedDiplomas = groupByInstitution(diplomas as DiplomaGroup[])

// Items shown in print mode: use featuredCourses if available, otherwise all courses
const printableGroups = (diplomas as DiplomaGroup[])
  .map(({ institution, featuredCourses = [], courses, printLimit }) => ({
    institution,
    courses: featuredCourses.length > 0 ? featuredCourses : courses.slice(0, printLimit ?? courses.length),
  }))
  .filter(({ courses }) => courses.length > 0)
---

<Section title={title}>
  {printMode && (
    <div class="print-diploma-list">
      {printableGroups.map(({ institution, courses: diplomaCourses }) => (
        <p><strong>{institution}:</strong> {diplomaCourses.join(" · ")}</p>
      ))}
    </div>
  )}
  {!printMode && Object.entries(groupedDiplomas).map(([institution, diplomaGroups]) => (
    <div>
      <h3>{institution}</h3>
      <ul>
        {
          diplomaGroups.map(({ area, studyType, courses }) => (
            courses.map((course) => (
              <li>
                <article>
                  <header>
                    <h4>{course}</h4>
                    <p>{area} - {studyType}</p>
                  </header>
                </article>
              </li>
            ))
          ))
        }
      </ul>
    </div>
  ))}
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-inline: -16px;
    margin-bottom: 2rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem 0;
  }

  article {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    gap: 16px;
    display: flex;
    flex-direction: column;
    padding: 16px;
    height: 100%;
  }

  article header {
    flex: 1;
  }

  article h4 {
    margin-bottom: 4px;
    font-size: 1rem;
  }

  article p {
    font-size: 0.75rem;
    line-height: 1.2rem;
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  .print-diploma-list { display: grid; gap: 0.25rem; }
  .print-diploma-list p { font-size: 0.72rem; line-height: 1.3; }
  .print-diploma-list strong { color: var(--color-text-primary); }

  @media (width <= 700px) {
    ul { margin-inline: 0; }
    article { border: none; box-shadow: 0 1px 1px var(--color-border); padding: 0 0 16px 0; }
  }

  @media print {
    .print-diploma-list { display: grid; }
  }
</style>
