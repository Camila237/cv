---
import Section from "../Section.astro"
import { getCv } from "@/data/cv"
import { getLabels } from "@/lib/i18n"

interface Props {
  print?: boolean
}

type Project = {
  name: string
  company?: string | null
  description: string
  highlights: string[]
  url?: string | null
}

const normalizeCompany = (value?: string | null) => (value ?? "").toLowerCase().replace(/[^a-z0-9]/g, "")
const { work, projects } = getCv(Astro.url.pathname)
const labels = getLabels(Astro.url.pathname)
const printMode = Astro.props.print ?? false
const projectList = projects as unknown as Project[]

const formatDate = (dateStr: string | number | Date | null) => {
  if (!dateStr) return labels.current
  return new Date(dateStr).toLocaleDateString(Astro.url.pathname.includes("/en") ? "en-US" : "es-ES", { month: "short", year: "numeric" })
}

const getDuration = (start: string | number | Date, end: string | number | Date | null) => {
  const startDate = new Date(start)
  const endDate = end ? new Date(end) : new Date()
  const months = (endDate.getFullYear() - startDate.getFullYear()) * 12 + endDate.getMonth() - startDate.getMonth()
  const years = Math.floor(months / 12)
  const remainingMonths = months % 12
  const parts = []
  if (years) parts.push(`${years} año${years > 1 ? "s" : ""}`)
  if (remainingMonths) parts.push(`${remainingMonths} mes${remainingMonths > 1 ? "es" : ""}`)
  return parts.join(" ") || "Menos de 1 mes"
}
---

<Section title={labels.experience}>
  <div class="experience-list">
    {
      work.map((job, index) => {
        const highlights = job.highlights ?? []
        const isComplementaryExperience = ["freelance", "personal", "personal projects", "proyectos personales"].includes(job.name.toLowerCase())
        const jobProjects = projectList.filter(
          (project) => normalizeCompany(project.company) === normalizeCompany(job.name),
        )

        return (
          <details class:list={["experience", { "complementary-experience": isComplementaryExperience }]} open={printMode || index === 0}>
            <summary>
              <span class="role">
                {job.position ? (
                  <Fragment>
                    <strong>{job.position}</strong>
                    <span>{job.name}</span>
                  </Fragment>
                ) : (
                  <strong>{job.name}</strong>
                )}
              </span>
              {!isComplementaryExperience && (
                <span class="period">
                  {formatDate(job.startDate)} — {formatDate(job.endDate)}
                </span>
              )}
            </summary>

            <div class="experience-content">
              <p>{job.summary}</p>
              {highlights.length > 0 && (
                <ul class:list={["work-highlights", { "current-role": !job.endDate }]}>
                  {highlights.map((item) => <li>{item}</li>)}
                </ul>
              )}

              {jobProjects.length > 0 && (
                <details class="project-details">
                  <summary>{labels.featuredProjects} ({jobProjects.length})</summary>
                  <ul class="project-list">
                    {jobProjects.map((project) => (
                      <li>
                        <div>
                          {project.url ? (
                            <Fragment>
                              <strong>{project.name}</strong>
                              <a class="project-link-hint" href={project.url} target="_blank" rel="noopener noreferrer">{labels.viewProject} ↗</a>
                            </Fragment>
                          ) : <strong>{project.name}</strong>}
                          <p>{project.description}</p>
                        </div>
                        {project.highlights?.length > 0 && <span>{project.highlights.join(" · ")}</span>}
                      </li>
                    ))}
                  </ul>
                </details>
              )}
            </div>
            {!isComplementaryExperience && job.startDate && <span class="print-duration">{getDuration(job.startDate, job.endDate)}</span>}
          </details>
        )
      })
    }
  </div>
</Section>

<style>
  .experience-list { display: grid; gap: 0.65rem; }
  .experience { border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-bg-card); }
  summary { cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.85rem 1rem; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: "+"; color: var(--color-text-light); font-size: 1.1rem; }
  details[open] > summary::after { content: "−"; }
  .role { display: grid; gap: 0.15rem; }
  .role strong { color: var(--color-text-primary); font-family: var(--font-sans); font-size: 0.95rem; }
  .role span, .period { color: var(--color-text-muted); font-size: 0.82rem; }
  .period { white-space: nowrap; }
  .experience-content { border-top: 1px solid var(--color-border); padding: 0.85rem 1rem 1rem; }
  .experience-content > p { font-size: 0.85rem; }
  .work-highlights { display: grid; gap: 0.35rem; margin: 0.7rem 0 0; }
  .work-highlights li { border-left: 2px solid var(--color-border-muted); color: var(--color-text-secondary); font-size: 0.78rem; line-height: 1.4; padding-left: 0.6rem; }
  .project-details { margin-top: 0.8rem; }
  .project-details > summary { border-top: 1px solid var(--color-border); color: var(--color-text-primary); font-size: 0.82rem; padding: 0.7rem 0 0; }
  .project-list { display: grid; gap: 0.65rem; margin: 0.75rem 0 0; }
  .project-list li { border-left: 2px solid var(--color-border-muted); padding-left: 0.7rem; }
  .project-list a, .project-list strong { color: var(--color-text-primary); font-size: 0.85rem; }
  .project-list a:hover { text-decoration: underline; }
  .project-link-hint { background: var(--color-bg-alt); border-radius: 999px; color: var(--color-text-secondary); display: inline-block; font-size: 0.65rem; font-weight: 500; margin-left: 0.45rem; padding: 0.12rem 0.4rem; white-space: nowrap; }
  .project-list p { font-size: 0.78rem; margin-top: 0.15rem; }
  .project-list span { color: var(--color-text-muted); display: block; font-size: 0.72rem; line-height: 1.4; margin-top: 0.25rem; }
  .print-duration { display: none; }
  @media (width <= 700px) { summary { align-items: flex-start; } .period { font-size: 0.72rem; } }
  @media print {
    .experience { border: 0; border-radius: 0; break-inside: avoid; position: relative; }
    .experience:not(:last-child) { border-bottom: 1px solid var(--color-border-muted); }
    .experience summary { cursor: default; display: block; padding: 0.35rem 0 0.15rem; }
    .experience summary::after { display: none; }
    .role { display: inline; }
    .role strong::after { content: ""; }
    .role span::before { content: " · "; }
    .role span { color: var(--color-text-primary); }
    .period { display: block; font-size: 0.72rem; margin-top: 0.1rem; }
    .complementary-experience .period { display: none; }
    .experience-content { border: 0; display: block; padding: 0 0 0.4rem; }
    .experience:not([open]) > .experience-content { display: block !important; }
    .experience-content > p { display: none; }
    .work-highlights { display: block; list-style: disc; margin: 0.15rem 0 0; padding-left: 1rem; }
    .work-highlights li { border: 0; font-size: 0.7rem; line-height: 1.25; padding-left: 0; }
    .work-highlights li:nth-child(n + 3) { display: none; }
    .work-highlights.current-role li:nth-child(n + 3) { display: list-item; }
    .project-details, .print-duration { display: none !important; }
  }
</style>
