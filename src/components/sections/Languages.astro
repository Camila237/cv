---
import Section from "../Section.astro"
import { getCv, getLocale } from "@/data/cv"
import { getLabels } from "@/lib/i18n"

interface Props {
  print?: boolean
}

const { languages } = getCv(Astro.url.pathname)
const labels = getLabels(Astro.url.pathname)
const locale = getLocale(Astro.url.pathname)

const getFluency = (fluency: string) => {
  if (fluency === "C2") {
    return locale === "es" ? "Nativo" : "Native"
  }
  return fluency
}

const printMode = Astro.props.print ?? false
---

<Section title={labels.languages}>
  {printMode ? (
    <div class="print-language-list">
      <p>
        {languages.map(({ language, fluency }, index) => (
          <>
            <span><strong>{language}:</strong> {getFluency(fluency)}</span>
            {index < languages.length - 1 && ' · '}
          </>
        ))}
      </p>
    </div>
  ) : (
    <ul>
      {
        languages.map(({ language, fluency }) => (
          <li>
            <span>{language}</span>
            <small>{getFluency(fluency)}</small>
          </li>
        ))
      }
    </ul>
  )}
</Section>

<style>
  /* Existing styles for non-print mode */
  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: inline-flex;
    align-items: center;
    background-color: #f5f5f5;
    border: 1px solid #ddd;
    border-radius: 9999px;
    padding: 0.4rem 0.8rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #333;
    gap: 6px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    transition: background 0.3s ease;
  }

  li:hover {
    background-color: #eaeaea;
  }

  li small {
    font-size: 0.75rem;
    font-weight: 400;
    color: #777;
  }

  /* New styles for print mode */
  .print-language-list { display: grid; gap: 0.25rem; }
  .print-language-list p { font-size: 0.72rem; line-height: 1.3; }
  .print-language-list strong { color: #222; }

  @media (width <= 700px) {
    ul {
      margin-inline: 0px;
    }

    article {
      border: none;
      box-shadow: 0 1px 1px #f2f2f2;
      padding: 0 0 16px 0;
    }
  }

  @media print {
    /* Hide the non-print list */
    ul {
        display: none;
    }

    /* Show the print list */
    .print-language-list {
        display: grid;
    }
  }
</style>

