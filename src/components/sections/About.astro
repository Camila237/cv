---
import Section from "../Section.astro"

import { getCv } from "@/data/cv"
import { getLabels } from "@/lib/i18n"
const { summary } = getCv(Astro.url.pathname).basics
const labels = getLabels(Astro.url.pathname)
---

<Section title={labels.profile}>
  <p class="profile-summary">
    {summary}
  </p>
</Section>

<style>
  @media print {
    .profile-summary { font-size: 0.78rem; line-height: 1.35; }
  }
</style>
